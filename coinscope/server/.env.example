PORT=5000
MONGO_URI=mongodb://localhost:27017/coinscope
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:3000

# CoinGecko is keyless on the public/free tier (2021-2022 era).
# Leaving this blank uses the public endpoint; if you have a Demo/Pro key
# you can paste it here and it will be sent as x-cg-demo-api-key.
COINGECKO_API_KEY=

# When true, the server skips CoinGecko entirely and serves deterministic mock
# data. Useful for offline demos. Defaults to false.
USE_MOCK_DATA=false
